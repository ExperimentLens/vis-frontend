{
  "name": "vite-template-redux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clear": "vite --force",
    "start": "vite",
    "strict-start": "npm run lint:src/app && npm run type-check && vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "lint:src/app": "eslint src/app",
    "lint:src/shared": "eslint src/shared",
    "lint:src/store": "eslint src/store",
    "lint:src/app:fix": "eslint --fix src/app",
    "lint:log": "eslint . --quiet --format stylish > eslint-errors.log"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-charts": "^8.27.0",
    "@mui/x-data-grid": "^8.27.1",
    "@mui/x-tree-view": "^8.27.1",
    "@reduxjs/toolkit": "^2.0.1",
    "@types/lodash": "^4.17.5",
    "@xyflow/react": "^12.4.2",
    "axios": "^1.6.8",
    "chroma-js": "^3.1.2",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lodash": "^4.17.23",
    "mathjs": "^13.2.0",
    "re-resizable": "^6.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.23.0",
    "react-vega": "^7.6.0",
    "ts-node": "^10.9.2",
    "vega": "^5.29.0",
    "vega-lite": "^5.18.1",
    "vega-tooltip": "^0.35.2",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.38.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "@eslint/js": "^9.38.4",
    "typescript-eslint": "^8.56.0",
    "jsdom": "^23.2.0",
    "prettier": "^3.2.1",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ajv": "^8.12.0"
  }
